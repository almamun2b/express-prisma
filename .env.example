NODE_ENV="development"
PORT=5000
APP_NAME="App Name"

DATABASE_URL="postgresql://user:password@localhost:5432/express_starter"

BCRYPT_SALT_ROUND=10

CLOUDINARY_CLOUD_NAME="dummy_cloud_name"
CLOUDINARY_API_KEY="dummy_api_key"
CLOUDINARY_API_SECRET="dummy_api_secret"

JWT_ACCESS_TOKEN_SECRET="super_secret_access_token_key"
JWT_ACCESS_TOKEN_SECRET_EXPIRES_IN="7d"
JWT_REFRESH_TOKEN_SECRET="super_secret_refresh_token_key"
JWT_REFRESH_TOKEN_SECRET_EXPIRES_IN="30d"
JWT_RESET_PASS_SECRET="super_secret_reset_password_key"
JWT_RESET_PASS_SECRET_EXPIRES_IN="15m"

CLIENT_URL="http://localhost:3000"

RESET_PASS_URL="http://localhost:3000/reset-password"

CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

GOOGLE_SMTP_SENDER_EMAIL="your-email@gmail.com"
GOOGLE_SMTP_APP_PASS="your-app-specific-password"
GOOGLE_SMTP_HOST="smtp.gmail.com"
GOOGLE_SMTP_PORT=587

BREVO_SMTP_SENDER_EMAIL="your-email@gmail.com"
BREVO_SMTP_API_KEY="api-key"

SUPER_ADMIN_EMAIL="superadmin@example.com"
SUPER_ADMIN_PASS="SuperAdmin@123"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASS="Admin@123"

REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_USERNAME="default"
REDIS_PASSWORD="redis_password"