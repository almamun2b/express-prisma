{
  "name": "express-prisma-postgresql-starter",
  "version": "1.0.0",
  "description": "Production-grade Express.js + Prisma + PostgreSQL + Redis starter template with strict TypeScript, secure authentication, and advanced querying.",
  "keywords": [
    "express",
    "prisma",
    "postgresql",
    "redis",
    "typescript",
    "boilerplate",
    "starter-kit",
    "rest-api",
    "authentication",
    "jwt",
    "zod",
    "winston-logger",
    "clean-architecture"
  ],
  "homepage": "https://github.com/almamun2b/express-prisma#readme",
  "bugs": {
    "url": "https://github.com/almamun2b/express-prisma/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almamun2b/express-prisma.git"
  },
  "license": "MIT",
  "author": "Al Mamun <almamun2b@gmail.com>",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && tsup",
    "vercel-build": "prisma generate && npm run build",
    "start": "node dist/server.js",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm lint && pnpm format:check && pnpm typecheck",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate",
    "db:seed": "prisma db seed",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.3",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
