### ============================================
### Run with `REST Client` extension for VS Code
### ============================================


@baseUrl = http://localhost:5000/api/v1
@accessToken = accessToken
@refreshToken = refreshToken
# @email = apitest@tensi.org
@email = super@gmail.com
@password = Password1#
@firstName = John
@lastName = Doe
@resetPassToken = resetPassToken
@newPassword = NewPassword1#
@verifyEmailOtp = 942176

### ============================================
### HEALTH CHECK
### ============================================

### Home
GET http://localhost:5000

### Health Check
GET {{baseUrl}}/health

### ============================================
### AUTH ENDPOINTS
### ============================================

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "firstName": "{{firstName}}",
  "lastName": "{{lastName}}",
  "email": "{{email}}",
  "password": "{{password}}"
}

### Resend Verification Code
POST {{baseUrl}}/auth/resend-verification-code
Content-Type: application/json

{
  "email": "{{email}}"
}

### Verify Email
POST {{baseUrl}}/auth/verify-email
Content-Type: application/json

{
  "email": "{{email}}",
  "code": "{{verifyEmailOtp}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Refresh Token
POST {{baseUrl}}/auth/refresh-token
Content-Type: application/json

### Logout
POST {{baseUrl}}/auth/logout
Content-Type: application/json

### Forgot Password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### Resend Forgot Password
POST {{baseUrl}}/auth/resend-forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### Reset Password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetPassToken}}",
  "newPassword": "{{newPassword}}"
}

### ============================================
### USER ENDPOINTS
### ============================================

@userId = 9b7a3fa1-6e1c-457d-872b-0b4efedb33e7
@oldPassword = Password1#
@newUserPassword = NewPassword1#

### Get All Users (Admin+)
GET {{baseUrl}}/users
Content-Type: application/json

### Get All Users - Filtered + Paginated (Admin+)
GET {{baseUrl}}/users?page=1&limit=5&sortBy=createdAt&sortOrder=desc&status=ACTIVE&createdAtFrom=2026-06-21&createdAtTo=2026-12-31
Content-Type: application/json

### Create User Manually (Admin+)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "email": "user10@example.com",
  "password": "SecurePass1#",
  "username": "user10",
  "role": "USER",
  "status": "ACTIVE",
  "firstName": "Manual",
  "lastName": "User",
  "gender": "MALE",
  "phone": "+1234567890"
}

### Get Own Profile
GET {{baseUrl}}/users/me
Content-Type: application/json

### Update Own Profile
PATCH {{baseUrl}}/users/me
Content-Type: application/json

{
  "firstName": "{{firstName}}",
  "lastName": "{{lastName}}",
  "phone": "+1234567890",
  "gender": "MALE",
  "bio": "Full Stack Engineer",
  "address": "New York",
  "dateOfBirth": "1992-08-15",
  "timezone": "America/New_York",
  "locale": "en-US"
}

### Upload / Replace Own Avatar (multipart/form-data)
PATCH {{baseUrl}}/users/me/avatar
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary

------WebKitFormBoundary
Content-Disposition: form-data; name="avatar"; filename="mamun.png"
Content-Type: image/png

< ./logs/mamun.png
------WebKitFormBoundary--

### Delete Own Avatar
DELETE {{baseUrl}}/users/me/avatar
Content-Type: application/json

### Change Own Password
PATCH {{baseUrl}}/users/me/change-password
Content-Type: application/json

{
  "oldPassword": "{{oldPassword}}",
  "newPassword": "{{newUserPassword}}"
}

### Get User by ID (Admin+)
GET {{baseUrl}}/users/{{userId}}
Content-Type: application/json

### Update User Status (Admin+)
PATCH {{baseUrl}}/users/{{userId}}/status
Content-Type: application/json

{
  "status": "ACTIVE"
}

### Update User Role (Super Admin only)
PATCH {{baseUrl}}/users/{{userId}}/role
Content-Type: application/json

{
  "role": "SUPER_ADMIN"
}

### Deactivate User (Admin+)
PATCH {{baseUrl}}/users/{{userId}}/deactivate
Content-Type: application/json

### Reactivate User (Admin+)
PATCH {{baseUrl}}/users/{{userId}}/reactivate
Content-Type: application/json

### Soft Delete User (Admin+)
DELETE {{baseUrl}}/users/{{userId}}
Content-Type: application/json

### Hard Delete User (Super Admin only)
DELETE {{baseUrl}}/users/{{userId}}/hard
Content-Type: application/json

