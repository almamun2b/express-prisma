### ============================================
### Run with `REST Client` extension for VS Code
### ============================================


@baseUrl = http://localhost:5000/api/v1
@accessToken = accessToken
@refreshToken = refreshToken
@email = apitest@tensi.org
@password = Password1#
@firstName = John
@lastName = Doe
@resetPassToken = resetPassToken
@newPassword = NewPassword1#
@verifyEmailOtp = 942176

### ============================================
### HEALTH CHECK
### ============================================

### Home
GET http://localhost:5000

### Health Check
GET {{baseUrl}}/health

### ============================================
### AUTH ENDPOINTS
### ============================================

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "firstName": "{{firstName}}",
  "lastName": "{{lastName}}",
  "email": "{{email}}",
  "password": "{{password}}"
}

### Resend Verification Code
POST {{baseUrl}}/auth/resend-verification-code
Content-Type: application/json

{
  "email": "{{email}}"
}

### Verify Email
POST {{baseUrl}}/auth/verify-email
Content-Type: application/json

{
  "email": "{{email}}",
  "code": "{{verifyEmailOtp}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Refresh Token
POST {{baseUrl}}/auth/refresh-token
Content-Type: application/json

### Logout
POST {{baseUrl}}/auth/logout
Content-Type: application/json

### Forgot Password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### Resend Forgot Password
POST {{baseUrl}}/auth/resend-forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### Reset Password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetPassToken}}",
  "newPassword": "{{newPassword}}"
}

### ============================================
### USER ENDPOINTS
### ============================================

### Get All Users
GET {{baseUrl}}/user

### Get Single User
GET {{baseUrl}}/user/9b7a3fa1-6e1c-457d-872b-0b4efedb33e7

### Create User
POST {{baseUrl}}/user
Content-Type: application/json

{
  "name": "John Doe",
  "email": "john@example.com"
}
