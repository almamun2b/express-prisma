model User {
  id       String  @id @default(uuid())
  email    String  @unique
  username String? @unique
  password String?

  role       UserRole   @default(USER)
  status     UserStatus @default(PENDING)
  isVerified Boolean    @default(false)
  verifiedAt DateTime?

  firstName   String?
  lastName    String?
  gender      Gender?
  phone       String?
  bio         String?   @db.Text
  address     String?
  dateOfBirth DateTime?
  timezone    String?   @default("UTC")
  locale      String?   @default("en")
  lastLoginAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  avatarId      String?        @unique
  avatar        Avatar?        @relation(fields: [avatarId], references: [id])
  authProviders AuthProvider[]

  @@index([email])
  @@map("users")
}

model Avatar {
  id           String   @id @default(uuid())
  publicId     String
  version      String?
  width        Int?
  height       Int?
  format       String?
  resourceType String?
  type         String?
  url          String
  contentType  String?
  size         Int?
  metadata     Json? // Need to check the type
  colors       Json? // Need to check the type
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?

  @@map("avatars")
}

model AuthProvider {
  id         String           @id @default(uuid())
  provider   AuthProviderName @default(CREDENTIAL)
  providerId String
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([provider, providerId])
  @@map("auth_providers")
}
