import dotenv from 'dotenv';
import { StatusCodes } from 'http-status-codes';
import { z } from 'zod';
import type { TJwtExpiresIn } from '../types/jwt.types';
import { AppError } from '../utils/appError';
import { Codes } from '../utils/codes';

dotenv.config();

const jwtExpiresSchema = z
  .string()
  .regex(/^\d+(ms|s|m|h|d|w|y)$/, {
    message: 'Must be valid JWT expiration (e.g., 2ms, 3s, 4m, 5h, 6d, 7w, 8y)',
  })
  .transform((val) => val as TJwtExpiresIn);

const positiveNumberSchema = z.coerce.number().int().positive();

const commaSeparatedStringArraySchema = z
  .string()
  .transform((val) => val.split(',').map((s) => s.trim()));

const rawEnvSchema = z.object({
  NODE_ENV: z.enum(['development', 'production']),
  PORT: positiveNumberSchema,
  DATABASE_URL: z.url(),
  BCRYPT_SALT_ROUND: positiveNumberSchema,

  CLOUDINARY_CLOUD_NAME: z.string(),
  CLOUDINARY_API_KEY: z.string(),
  CLOUDINARY_API_SECRET: z.string(),

  JWT_ACCESS_TOKEN_SECRET: z.string(),
  JWT_ACCESS_TOKEN_SECRET_EXPIRES_IN: jwtExpiresSchema,
  JWT_REFRESH_TOKEN_SECRET: z.string(),
  JWT_REFRESH_TOKEN_SECRET_EXPIRES_IN: jwtExpiresSchema,
  JWT_RESET_PASS_SECRET: z.string(),
  JWT_RESET_PASS_SECRET_EXPIRES_IN: jwtExpiresSchema,

  OPEN_ROUTER_API_KEY: z.string(),

  STRIPE_SECRET_KEY: z.string(),
  STRIPE_WEBHOOK_SECRET: z.string(),

  CLIENT_URL: z.url(),
  CORS_ORIGINS: commaSeparatedStringArraySchema,

  RESET_PASS_URL: z.url(),

  EMAIL_SENDER_EMAIL: z.email(),
  EMAIL_SENDER_APP_PASS: z.string(),
  EMAIL_SENDER_HOST: z.string(),
  EMAIL_SENDER_PORT: positiveNumberSchema,

  SUPER_ADMIN_EMAIL: z.email(),
  SUPER_ADMIN_PASS: z.string(),
  ADMIN_EMAIL: z.email(),
  ADMIN_PASS: z.string(),

  REDIS_HOST: z.string(),
  REDIS_PORT: positiveNumberSchema,
  REDIS_USERNAME: z.string(),
  REDIS_PASSWORD: z.string(),
});

const envSchema = rawEnvSchema.transform((env) => ({
  nodeEnv: env.NODE_ENV,
  port: env.PORT,
  databaseUrl: env.DATABASE_URL,
  bcryptSaltRound: env.BCRYPT_SALT_ROUND,
  cloudinary: {
    cloudName: env.CLOUDINARY_CLOUD_NAME,
    apiKey: env.CLOUDINARY_API_KEY,
    apiSecret: env.CLOUDINARY_API_SECRET,
  },
  jwt: {
    accessTokenSecret: env.JWT_ACCESS_TOKEN_SECRET,
    accessTokenSecretExpiresIn: env.JWT_ACCESS_TOKEN_SECRET_EXPIRES_IN,
    refreshTokenSecret: env.JWT_REFRESH_TOKEN_SECRET,
    refreshTokenSecretExpiresIn: env.JWT_REFRESH_TOKEN_SECRET_EXPIRES_IN,
    resetPassSecret: env.JWT_RESET_PASS_SECRET,
    resetPassSecretExpiresIn: env.JWT_RESET_PASS_SECRET_EXPIRES_IN,
  },
  openRouter: {
    apiKey: env.OPEN_ROUTER_API_KEY,
  },
  stripe: {
    secretKey: env.STRIPE_SECRET_KEY,
    webhookSecret: env.STRIPE_WEBHOOK_SECRET,
  },
  clientUrl: env.CLIENT_URL,
  corsOrigins: env.CORS_ORIGINS,
  resetPassLink: env.RESET_PASS_URL,
  emailSender: {
    email: env.EMAIL_SENDER_EMAIL,
    appPass: env.EMAIL_SENDER_APP_PASS,
    host: env.EMAIL_SENDER_HOST,
    port: env.EMAIL_SENDER_PORT,
  },
  defaultUsers: {
    superAdminEmail: env.SUPER_ADMIN_EMAIL,
    superAdminPassword: env.SUPER_ADMIN_PASS,
    adminEmail: env.ADMIN_EMAIL,
    adminPassword: env.ADMIN_PASS,
  },
  redis: {
    host: env.REDIS_HOST,
    port: env.REDIS_PORT,
    username: env.REDIS_USERNAME,
    password: env.REDIS_PASSWORD,
  },
}));

type TEnv = z.infer<typeof envSchema>;

const buildEnv = () => {
  const parsed = envSchema.safeParse(process.env);

  if (!parsed.success) {
    const formatted = z.treeifyError(parsed.error);
    throw new AppError(
      StatusCodes.INTERNAL_SERVER_ERROR,
      `Invalid environment configuration: ${JSON.stringify(formatted, null, 2)}`,
      Codes.INTERNAL_SERVER_ERROR
    );
  }

  return parsed.data;
};

let env: TEnv;

try {
  env = buildEnv();
} catch (error) {
  if (error instanceof AppError) {
    console.error(`[env] Error: ${error.message}\n`, error);
    process.exit(1);
  }
  throw error;
}

export { env };
